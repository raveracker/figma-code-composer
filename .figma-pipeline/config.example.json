{
  "$schema": "./config.schema.json",
  "version": "1.0",
  "project": {
    "name": "acme-web",
    "description": "Acme storefront — React 19 + Tailwind v4."
  },
  "framework": {
    "name": "react",
    "variant": "next",
    "version": "19.0.0"
  },
  "language": "ts",
  "cssSystem": {
    "name": "tailwind-v4",
    "config": {
      "prefix": "tw:",
      "configFile": "src/styles/tailwind.css",
      "extendTailwindMergePath": "src/lib/utils.ts"
    }
  },
  "tokens": {
    "strategy": "tailwind-css-vars",
    "outputDir": "src/styles/tokens",
    "files": ["primitives.css", "semantic.css", "components.css"],
    "namingConvention": "kebab-case",
    "prefix": "--app-",
    "fileLayout": "split"
  },
  "components": {
    "designMethodology": "atomic",
    "atomicLayout": {
      "atomsDir": "src/components/atoms",
      "moleculesDir": "src/components/molecules",
      "organismsDir": "src/components/organisms",
      "templatesDir": "src/components/templates"
    },
    "namingConvention": "PascalCase",
    "fileNaming": "match-component"
  },
  "icons": {
    "outputDir": "src/components/icons",
    "barrelFile": "index.ts",
    "fillModel": "mixed"
  },
  "stories": {
    "enabled": true,
    "framework": "storybook",
    "outputDir": "co-located",
    "titleConvention": "Components/{Layer}/{Name}"
  },
  "tests": {
    "unit": {
      "enabled": true,
      "framework": "vitest",
      "outputDir": "co-located",
      "testingLibrary": "react-testing-library"
    },
    "e2e": {
      "enabled": true,
      "framework": "playwright",
      "outputDir": "e2e"
    }
  },
  "designSystem": {
    "name": "none"
  },
  "figma": {
    "mcpServerName": "figma",
    "defaultFileKeys": [],
    "linkConvention": "design-addon"
  },
  "writeScope": {
    "allowedDirs": [
      "src/components/**",
      "src/styles/tokens/**",
      "src/components/icons/**"
    ],
    "alwaysBlocked": [
      "node_modules/**",
      "dist/**",
      ".turbo/**",
      "package-lock.json",
      "yarn.lock",
      "pnpm-lock.yaml",
      ".env",
      ".env.*"
    ]
  },
  "tools": {
    "claudeCode": true,
    "cursor": true,
    "codexCli": true
  },
  "complexity": {
    "enabled": true,
    "thresholds": { "trivial": 20, "moderate": 50, "complex": 80 }
  },
  "knowledgeGraph": {
    "enabled": true,
    "storeDir": ".figma-pipeline/kg",
    "embeddings": { "provider": "local", "model": "Xenova/all-MiniLM-L6-v2" },
    "retention": { "handoverDays": 30, "stagingDays": 7 },
    "visualRegression": { "enabled": false, "thresholdPercent": 2 }
  },
  "rtk": {
    "installed": false
  }
}
