{
  "name": "figma-code-composer",
  "version": "0.1.0",
  "description": "Drop-in, framework-agnostic Figma-to-code multi-agent pipeline scaffold for Claude Code, Cursor, and Codex CLI. Includes a knowledge-graph CLI for cross-run component reuse, complexity-driven routing, and handover-based session optimization.",
  "keywords": [
    "figma",
    "design-system",
    "code-generation",
    "claude-code",
    "cursor",
    "codex",
    "ai-agents",
    "mcp",
    "tokens",
    "scaffold",
    "knowledge-graph",
    "rag"
  ],
  "license": "MIT",
  "author": {
    "name": "Allan Jeo Joseph",
    "email": "allanjeo95@gmail.com",
    "url": "https://github.com/raveracker"
  },
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "figma-code-composer": "bin/figma-code-composer.js",
    "fcc": "bin/figma-code-composer.js"
  },
  "files": [
    "bin/",
    ".claude/",
    "!.claude/logs/",
    "!.claude/settings.local.json",
    ".cursor/",
    "!.cursor/.cursorignore",
    ".codex/",
    ".figma-pipeline/",
    "assets/",
    "skills-lock.json",
    "CLAUDE.md",
    "AGENTS.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test:cli": "node bin/figma-code-composer.js init --dry-run /tmp/fcc-dry-run-test",
    "validate:config": "npx --yes --offline ajv-cli@5 validate -s .figma-pipeline/config.schema.json -d .figma-pipeline/config.example.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raveracker/figma-code-composer.git"
  },
  "bugs": {
    "url": "https://github.com/raveracker/figma-code-composer/issues"
  },
  "homepage": "https://github.com/raveracker/figma-code-composer#readme",
  "publishConfig": {
    "access": "public"
  }
}
