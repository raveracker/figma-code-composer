# Only items explicitly listed in package.json "files" are published.
# This file further filters to keep the tarball clean.

.git/
.github/
.DS_Store
node_modules/
graphify-out/
.gitignore
.idea/
.vscode/

# Logs (anywhere)
*.log
**/*.log
.claude/logs/
**/logs/

# Local-only configs that should never ship
.cursorignore
.claude/settings.local.json
**/settings.local.json

# Dev scratch
/tmp/
*.tgz
