# Only items explicitly listed in package.json "files" are published.
# This file is a belt-and-suspenders fallback for editor/CI noise that
# might land in the package root.

.git/
.github/
.DS_Store
*.log
node_modules/
graphify-out/
.gitignore
.idea/
.vscode/

# Local-only configs that should never ship
.mcp.json
.cursorignore

# Dev scratch
/tmp/
*.tgz
